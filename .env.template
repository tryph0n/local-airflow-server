# GitHub Configuration
GITHUB_REPO=your-github-username/your-repo-name
# Generate a Personal Access Token at https://github.com/settings/tokens (needs repo scope)
GITHUB_PAT=your-github-pat-here

# AWS Configuration
AWS_ACCESS_KEY_ID=your-aws-access-key-here
AWS_SECRET_ACCESS_KEY=your-aws-secret-key-here
AWS_DEFAULT_REGION=eu-west-3
KEY_PAIR_NAME=airflow-mlflow
# Ubuntu AMI ID varies by region - find yours at https://cloud-images.ubuntu.com/locator/ec2/
AMI_ID=ami-xxxxxxxxxxxxxxxxx
SECURITY_GROUP_ID=sg-xxxxxxxxxxxxxxxxx
INSTANCE_TYPE=t3.small

# MLflow Configuration
MLFLOW_TRACKING_URI=https://your-mlflow-server-url/
MLFLOW_EXPERIMENT_NAME=california_housing

# SSH Private Key (for connecting to EC2)
# Paste the entire contents of your .pem key file, including BEGIN and END lines
SSH_PRIVATE_KEY_CONTENT="-----BEGIN RSA PRIVATE KEY-----
your-private-key-content-here
-----END RSA PRIVATE KEY-----"

# On Linux, set this to your host user ID (run: id -u)
AIRFLOW_UID=1000

# Ngrok Configuration (optional - for exposing Airflow UI publicly)
# Get your auth token at https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=your-ngrok-authtoken-here
